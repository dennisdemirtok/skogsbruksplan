# =============================================================
# SkogsplanSaaS Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# --- Database ---
POSTGRES_DB=skogsplan
POSTGRES_USER=skogsplan
POSTGRES_PASSWORD=skogsplan
DATABASE_URL=postgresql+asyncpg://skogsplan:skogsplan@db:5432/skogsplan

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Backend / FastAPI ---
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# --- Skogsstyrelsen API (Swedish Forest Agency) ---
SKOGSSTYRELSEN_API_KEY=
SKOGSSTYRELSEN_BASE_URL=https://geodpags.skogsstyrelsen.se/geodataport/

# --- Lantmateriet API (Swedish Land Survey) ---
LANTMATERIET_API_KEY=
LANTMATERIET_BASE_URL=https://api.lantmateriet.se/

# --- File Storage ---
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=50

# --- PDF Generation ---
PDF_OUTPUT_DIR=/app/data/pdfs

# --- Logging ---
LOG_LEVEL=INFO

# --- Environment ---
ENVIRONMENT=development
