*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Node / Frontend ---
node_modules/
.vite/
dist/
*.local
.eslintcache
.npm
.yarn/

# --- Environment files ---
.env
.env.local
.env.*.local
!.env.example
!backend/.env.example

# --- Docker ---
docker-compose.override.yml

# --- Database ---
*.sql.backup
*.dump

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

