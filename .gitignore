*.tif
*.tiff
*.laz
*.las
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.gpkg
data/rasters/
data/uploads/
data/pdfs/

# --- Logs ---
*.log
logs/

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# --- Alembic ---
alembic/versions/*.pyc

# --- Misc ---
