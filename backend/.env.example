# =============================================================
# SkogsplanSaaS Backend Environment Variables
# Copy this file to .env for local development outside Docker
# =============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://skogsplan:skogsplan@localhost:5432/skogsplan

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# --- Skogsstyrelsen API (Swedish Forest Agency) ---
SKOGSSTYRELSEN_API_BASE=https://api.skogsstyrelsen.se/skogligagrunddata/v2
SKOGSSTYRELSEN_API_KEY=

# --- Lantmateriet API (Swedish Land Survey) ---
LANTMATERIET_API_BASE=https://api.lantmateriet.se/distribution/produkter/fastighet/v3
LANTMATERIET_API_KEY=

# --- S3 / Object Storage ---
S3_BUCKET=skogsplan-uploads
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-north-1

# --- File Storage ---
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# --- Raster data path (GeoTIFF files from Skogsstyrelsen) ---
RASTER_DATA_PATH=/data/rasters

# --- PDF Generation ---
PDF_OUTPUT_DIR=./data/pdfs

# --- Logging ---
LOG_LEVEL=DEBUG

# --- Environment ---
ENVIRONMENT=development
